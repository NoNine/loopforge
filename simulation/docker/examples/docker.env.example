# Docker harness bootstrap defaults for role-step readiness gates.
#
# Copy this file outside committed examples before using real values. The
# harness writes generated state, staged artifacts, exported artifacts,
# evidence, and bounded logs under generated/simulation/docker/$HARNESS_RUN_ID.

HARNESS_MODE=docker-simulation

# HARNESS_SET_ID names reusable resources. Leave HARNESS_RUN_ID empty so
# init-run generates an immutable attempt identity.
HARNESS_SET_ID=default
HARNESS_RUN_ID=

# Optional browser-visible loopback ports. Leave unset for init-run and
# commands that render config to select available local ports and persist them
# for the run.
# HARNESS_GERRIT_HTTP_HOST_PORT=8081
# HARNESS_JENKINS_HTTP_HOST_PORT=8082

# Version Baseline
HARNESS_UBUNTU_IMAGE=ubuntu:24.04
HARNESS_UBUNTU_BASELINE_VERSION=24.04.4
HARNESS_UBUNTU_BASELINE_RELEASE=24.04
HARNESS_UBUNTU_BASELINE_CODENAME=noble
HARNESS_JAVA_BASELINE=21
HARNESS_GERRIT_BASELINE=3.13.6
HARNESS_JENKINS_BASELINE=2.555.3
HARNESS_JENKINS_PLUGIN_MANAGER_BASELINE=2.15.0

# LDAP service used for reachability and seeded-directory checks.
HARNESS_LDAP_IMAGE=osixia/openldap:1.5.0
HARNESS_LDAP_DOMAIN=example.test
HARNESS_LDAP_BASE_DN=dc=example,dc=test
HARNESS_LDAP_ADMIN_PASSWORD=admin-password
HARNESS_LDAP_CONFIG_PASSWORD=config-password
HARNESS_LDAP_BIND_USER=readonly
# Simulation-owned fake LDAP bind password for the local LDAP container. Do not
# replace this with a real organization LDAP secret.
HARNESS_LDAP_BIND_PASSWORD=readonly-password

# Public internet fallback on target hosts is simulation-only. Application
# artifacts must be prepared in the bundle factory and staged to targets.
HARNESS_PUBLIC_INTERNET_FALLBACK_LABEL=simulation-only

# Operator templates snapshotted under source-inputs by init-run. The first
# successful start publishes the stable effective bundle under runtime-inputs.
HARNESS_GERRIT_ENV_FILE=examples/gerrit.env.example
HARNESS_JENKINS_CONTROLLER_ENV_FILE=examples/jenkins-controller.env.example
HARNESS_JENKINS_AGENT_ENV_FILE=examples/jenkins-agent.env.example
HARNESS_INTEGRATION_ENV_FILE=examples/integration.env.example

# Docker v1 output roots are fixed under the repo-local generated/ directory.
# Use HARNESS_SET_ID to select reusable resources. Run output is isolated by
# the immutable HARNESS_RUN_ID; do not set output-directory overrides.
