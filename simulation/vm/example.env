# VM harness bootstrap defaults for M1 read-only run state.
#
# Copy this file outside committed examples before using real values. The
# harness writes generated state, evidence, and bounded logs under
# generated/simulation/vm/$HARNESS_RUN_ID and reusable VM-set state under
# generated/simulation/vm/vm-sets/$LOOPFORGE_VM_SET_ID.

HARNESS_MODE=vm-simulation

# Bootstrap identity. LOOPFORGE_VM_SET_ID names reusable VM infrastructure;
# HARNESS_RUN_ID names one run's inputs, logs, evidence, and review output.
HARNESS_RUN_ID=manual
LOOPFORGE_VM_SET_ID=default

# Version Baseline
HARNESS_UBUNTU_BASELINE_VERSION=24.04.4
HARNESS_UBUNTU_BASELINE_RELEASE=24.04
HARNESS_UBUNTU_BASELINE_CODENAME=noble
HARNESS_JAVA_BASELINE=21
HARNESS_GERRIT_BASELINE=3.13.6
HARNESS_JENKINS_BASELINE=2.555.3
HARNESS_JENKINS_PLUGIN_MANAGER_BASELINE=2.15.0

# Simulation-owned LDAP defaults. Do not replace these with organization
# secrets; VM LDAP seeding and runtime proof are implemented in later
# milestones.
HARNESS_LDAP_DOMAIN=example.test
HARNESS_LDAP_BASE_DN=dc=example,dc=test
HARNESS_LDAP_BIND_USER=readonly
HARNESS_LDAP_BIND_PASSWORD=readonly-password

# Public internet fallback on target hosts is simulation-only. Application
# artifacts must be prepared in the bundle factory and staged to targets.
HARNESS_PUBLIC_INTERNET_FALLBACK_LABEL=simulation-only

# Operator input files copied into run-scoped runtime inputs by init-run.
HARNESS_GERRIT_ENV_FILE=examples/gerrit.env.example
HARNESS_JENKINS_CONTROLLER_ENV_FILE=examples/jenkins-controller.env.example
HARNESS_JENKINS_AGENT_ENV_FILE=examples/jenkins-agent.env.example
HARNESS_INTEGRATION_ENV_FILE=examples/integration.env.example

# VM output roots are fixed under the repo-local generated/ directory. Use
# HARNESS_RUN_ID and LOOPFORGE_VM_SET_ID to isolate runs and VM sets.
