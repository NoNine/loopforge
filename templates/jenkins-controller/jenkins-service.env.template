# Jenkins controller runtime service settings.
# Render from a reviewed env file before applying to the target service.

JENKINS_HOME={{JENKINS_HOME}}
JENKINS_PORT={{JENKINS_HTTP_PORT}}
JENKINS_USER={{JENKINS_RUNTIME_ACCOUNT}}
JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
JAVA_ARGS=-Djenkins.install.runSetupWizard=false -Dcasc.jenkins.config={{JENKINS_HOME}}/jcasc/jenkins.yaml
