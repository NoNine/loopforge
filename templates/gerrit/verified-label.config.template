# Template: Gerrit Verified label definition
#
# Purpose:
# - Define the Verified label required by Jenkins Gerrit Trigger voting.
# - `target-deployment` workflow applies this label globally through reviewed
#   All-Projects project configuration in the shared integration step.
#
# This is a declarative template, not an executable script.

[label "Verified"]
	function = NoBlock
	value = -1 Fails
	value =  0 No score
	value = +1 Verified
	defaultValue = 0
