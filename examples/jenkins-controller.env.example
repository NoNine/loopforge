# Jenkins controller role env example.
# Copy to a local env file and replace every placeholder before use.

JENKINS_HOST="<jenkins.internal.example>"
JENKINS_URL="<https-or-http-jenkins-url>"
JENKINS_HTTP_PORT="<8080>"
JENKINS_RUNTIME_ACCOUNT="<jenkins>"
JENKINS_HOME="<path-to-jenkins-home>"
JENKINS_ARTIFACT_DIR="<path-to-staged-jenkins-artifacts>"

LDAP_URL="<ldap-url>"
LDAP_BIND_DN="<ldap-bind-dn>"
LDAP_USER_BASE="<ldap-user-base>"
LDAP_GROUP_BASE="<ldap-group-base>"
JENKINS_ADMIN_GROUP="<ldap-backed-jenkins-admin-group>"

GERRIT_HOST="<gerrit.internal.example>"
GERRIT_HTTP_URL="<https-or-http-gerrit-url>"
GERRIT_SSH_PORT="<29418>"
JENKINS_GERRIT_ACCOUNT="<jenkins-gerrit-service-account>"

JENKINS_AGENT_HOST="<agent.internal.example>"
JENKINS_AGENT_SSH_PORT="<22>"
JENKINS_AGENT_ACCOUNT="<jenkins-agent>"
JENKINS_AGENT_LABEL="<review-agent>"
