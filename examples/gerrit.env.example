# Gerrit role env example.
# Copy to a reviewed local env file before production-like use. The Docker
# harness may use these defaults directly for role-gate validation.

GERRIT_VERSION="3.13.6"
GERRIT_JAVA_VERSION="21"
GERRIT_UBUNTU_RELEASE="24.04"
GERRIT_UBUNTU_CODENAME="noble"

GERRIT_HOST="gerrit-target"
GERRIT_HTTP_PORT="8080"
GERRIT_SSH_PORT="29418"
GERRIT_RUNTIME_ACCOUNT="gerrit"
GERRIT_SITE_PATH="/harness/state/site"

GERRIT_ARTIFACT_OUTPUT_DIR="/harness/state/artifacts/gerrit"
GERRIT_STAGED_ARTIFACT_DIR="/harness/staged"
GERRIT_PLUGIN_LIST="replication,reviewnotes,download-commands"
GERRIT_OS_DEPENDENCIES="ca-certificates,curl,git,openssh-client,openjdk-21-jre-headless,rsync,tar,unzip,wget"

LDAP_URL="ldap://ldap:389"
LDAP_BIND_DN="cn=readonly,dc=example,dc=test"
LDAP_USER_BASE="ou=people,dc=example,dc=test"
LDAP_GROUP_BASE="ou=groups,dc=example,dc=test"

GERRIT_ADMIN_ACCOUNT="gerrit-admin"
GERRIT_ADMIN_GROUP="gerrit-admins"
JENKINS_GERRIT_INTEGRATION_ACCOUNT="jenkins-gerrit"
JENKINS_GERRIT_INTEGRATION_GROUP="jenkins-gerrit-integration"
JENKINS_GERRIT_PUBLIC_KEY_FILE="/harness/staged/jenkins-gerrit.pub"

GERRIT_VERIFICATION_PROJECT="verification-disposable-gerrit"
GERRIT_VERIFICATION_REF_PATTERN="refs/*"
GERRIT_VERIFICATION_MODE="docker-harness-simulation"
GERRIT_EVIDENCE_DIR="/harness/evidence"
GERRIT_LOG_DIR="/harness/logs"
