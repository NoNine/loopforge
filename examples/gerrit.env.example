# Gerrit role env example.
# Copy to a local env file and replace every placeholder before use.

GERRIT_HOST="<gerrit.internal.example>"
GERRIT_HTTP_PORT="<8080>"
GERRIT_SSH_PORT="<29418>"
GERRIT_RUNTIME_ACCOUNT="<gerrit>"
GERRIT_SITE_PATH="<path-to-gerrit-site>"
GERRIT_ARTIFACT_DIR="<path-to-staged-gerrit-artifacts>"

LDAP_URL="<ldap-url>"
LDAP_BIND_DN="<ldap-bind-dn>"
LDAP_USER_BASE="<ldap-user-base>"
LDAP_GROUP_BASE="<ldap-group-base>"

GERRIT_ADMIN_ACCOUNT="<ldap-backed-gerrit-admin>"
JENKINS_GERRIT_ACCOUNT="<jenkins-gerrit-service-account>"
JENKINS_GERRIT_PUBLIC_KEY="<path-to-jenkins-gerrit-public-key>"
