# Gerrit role env example.
# Copy to a reviewed local env file before production-like use. The Docker
# harness may use these defaults directly for role-gate validation.

GERRIT_HOST="gerrit-target"
GERRIT_HTTP_PORT="8080"
GERRIT_SSH_PORT="29418"
GERRIT_RUNTIME_ACCOUNT="gerrit"
GERRIT_RUNTIME_GROUP="gerrit"
GERRIT_SITE_PATH="/srv/gerrit"

GERRIT_LOCAL_ARTIFACT_OUTPUT_DIR="simulation/state/local/gerrit/artifacts"
GERRIT_ARTIFACT_OUTPUT_DIR="simulation/state/local/gerrit/artifacts"
GERRIT_STAGED_ARTIFACT_DIR="simulation/state/local/gerrit/staged"
GERRIT_PLUGIN_LIST="events-log,metrics-reporter-prometheus,healthcheck"
GERRIT_WAR_SOURCE=""
GERRIT_PLUGIN_SOURCE_DIR=""
GERRIT_DOWNLOAD_ARTIFACTS="1"
GERRIT_OS_DEPENDENCIES="ca-certificates,curl,git,ldap-utils,openssh-client,openjdk-21-jre-headless,rsync,tar,unzip,wget"

LDAP_URL="ldap://ldap:389"
LDAP_BIND_DN="cn=readonly,dc=example,dc=test"
LDAP_BIND_PASSWORD_FILE=""
# Optional fallback when a reviewed bind password file is not used.
LDAP_BIND_PASSWORD=""
LDAP_USER_BASE="ou=people,dc=example,dc=test"
LDAP_GROUP_BASE="ou=groups,dc=example,dc=test"

GERRIT_ADMIN_ACCOUNT="gerrit-admin"
GERRIT_ADMIN_GROUP="gerrit-admins"

GERRIT_VERIFICATION_PROJECT="verification-disposable-gerrit"
GERRIT_VERIFICATION_REF_PATTERN="refs/*"
GERRIT_VERIFICATION_MODE="docker-harness-simulation"
GERRIT_EVIDENCE_DIR="simulation/state/local/gerrit/evidence"
GERRIT_LOG_DIR="logs/gerrit"
