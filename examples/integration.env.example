# Cross-role integration env example.
# Keep shared integration values here, not in role-local env files.

# Standard Interfaces contract.
# The shared integration helper uses SSH as the common OS/control-plane
# interface for Docker simulation targets, VM simulation targets, and target
# deployment hosts. Service endpoints such as Gerrit HTTP, Gerrit SSH, Jenkins
# HTTP, and Jenkins-to-agent SSH remain in the role env files.
#
# INTEGRATION_MODE is one of:
# - docker-simulation
# - vm-simulation
# - target-deployment
INTEGRATION_MODE="docker-simulation"

# Gerrit target OS SSH access.
# INTEGRATION_GERRIT_TARGET_SSH_HOST="gerrit-target"
# INTEGRATION_GERRIT_TARGET_SSH_PORT="22"
# INTEGRATION_GERRIT_TARGET_SSH_USER="ci-operator"
# INTEGRATION_GERRIT_TARGET_SSH_IDENTITY_FILE="/path/to/operator-key"
# INTEGRATION_GERRIT_TARGET_SSH_KNOWN_HOSTS_FILE="/path/to/known_hosts"

# Jenkins controller target OS SSH access.
# INTEGRATION_JENKINS_CONTROLLER_TARGET_SSH_HOST="jenkins-controller-target"
# INTEGRATION_JENKINS_CONTROLLER_TARGET_SSH_PORT="22"
# INTEGRATION_JENKINS_CONTROLLER_TARGET_SSH_USER="ci-operator"
# INTEGRATION_JENKINS_CONTROLLER_TARGET_SSH_IDENTITY_FILE="/path/to/operator-key"
# INTEGRATION_JENKINS_CONTROLLER_TARGET_SSH_KNOWN_HOSTS_FILE="/path/to/known_hosts"

# Jenkins agent target OS SSH access.
# INTEGRATION_JENKINS_AGENT_TARGET_SSH_HOST="jenkins-agent-target"
# INTEGRATION_JENKINS_AGENT_TARGET_SSH_PORT="22"
# INTEGRATION_JENKINS_AGENT_TARGET_SSH_USER="ci-operator"
# INTEGRATION_JENKINS_AGENT_TARGET_SSH_IDENTITY_FILE="/path/to/operator-key"
# INTEGRATION_JENKINS_AGENT_TARGET_SSH_KNOWN_HOSTS_FILE="/path/to/known_hosts"

# Gerrit ACL workflow mode.
# target-deployment defaults to create-review.
# docker-simulation and vm-simulation default to create-review-and-submit.
# apply-direct is an explicit simulation-only fallback.
# INTEGRATION_GERRIT_ACL_MODE="create-review-and-submit"
# INTEGRATION_ALLOW_SIMULATION_DIRECT_ACL_APPLY="0"

JENKINS_SHARED_GROUP="jenkins-share"
JENKINS_SHARED_GROUP_GID="61040"
JENKINS_SHARED_STORAGE_PATH="/mnt/jenkins-shared"
GERRIT_TRIGGER_SERVER_NAME="gerrit"
JENKINS_VERIFICATION_JOB="gerrit-verification"
JENKINS_GERRIT_TOKEN_ID="jenkins-trigger"
LOOPFORGE_OPERATOR_ACCOUNT="ci-operator"
LOOPFORGE_OPERATOR_GROUP="ci-operator"
LOOPFORGE_OPERATOR_UID="61000"
LOOPFORGE_OPERATOR_GID="61000"
