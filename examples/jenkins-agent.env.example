# Jenkins SSH build-agent role env example.
# Copy to a local env file and replace every placeholder before use.

JENKINS_AGENT_HOST="<agent.internal.example>"
JENKINS_AGENT_SSH_PORT="<22>"
JENKINS_AGENT_ACCOUNT="<jenkins-agent>"
JENKINS_AGENT_REMOTE_FS="<path-to-agent-workdir>"
JENKINS_AGENT_LABEL="<review-agent>"
JENKINS_AGENT_ARTIFACT_DIR="<path-to-staged-agent-artifacts>"
JENKINS_AGENT_PUBLIC_KEY="<path-to-jenkins-agent-public-key>"
